# ─── Payworks login ──────────────────────────────────────────────────────────
# Two login mechanisms are supported. The choice is automatic:
#
#   • Set PAYWORKS_CUSTOMER  -> LEGACY login (customer number + basic auth via
#                               the external authenticator service). Uses
#                               PAYWORKS_USER_NAME + PAYWORKS_PASSWORD.
#
#   • Leave PAYWORKS_CUSTOMER blank -> NEW browser/email login (Playwright
#                               headless OIDC/SSO). Uses PAYWORKS_EMAIL +
#                               PAYWORKS_PASSWORD. Requires a one-time
#                               `npm run login` (node src/interactive-login.js) to
#                               complete SMS 2FA and remember the device.

# New browser/email login:
PAYWORKS_EMAIL=
PAYWORKS_PASSWORD=

# Legacy login (leave PAYWORKS_CUSTOMER blank to use the new login above):
PAYWORKS_USER_NAME=
PAYWORKS_CUSTOMER=

# ─── OpenAI (employee gender enrichment) ─────────────────────────────────────
# Disabled by default. Set ENABLE_AI_GENDER=true to infer employee gender from
# first names via OpenAI during the Employees load (requires OPENAI_API_KEY).
# When disabled, the Employees `gender` column is loaded NULL.
ENABLE_AI_GENDER=false
OPENAI_API_KEY=

# ─── SQL Server ──────────────────────────────────────────────────────────────
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_SERVER=
MSSQL_DATABASE=PayworksDataWarehouse
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_REQUEST_TIMEOUT=20000
# Optional: connect by fixed TCP port (recommended for local SQL Express).
# When set, the named instance in MSSQL_SERVER is ignored and SQL Browser is
# not needed. Configure the instance to listen on this port (e.g. 1433).
MSSQL_PORT=1433
