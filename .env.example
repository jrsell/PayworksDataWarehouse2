# ─── Payworks login (email-based — the normal way) ───────────────────────────
PAYWORKS_EMAIL=
PAYWORKS_PASSWORD=

# Legacy login (optional): set PAYWORKS_CUSTOMER (+ PAYWORKS_USER_NAME) to use the
# older customer-number login instead of the email login above. Leave blank normally.
PAYWORKS_USER_NAME=
PAYWORKS_CUSTOMER=

# ─── SQL Server ──────────────────────────────────────────────────────────────
MSSQL_SERVER=NICEASUS\SQLEXPRESS
MSSQL_PORT=1433
MSSQL_DATABASE=PayworksDataWarehouse
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_REQUEST_TIMEOUT=20000
